# URL du backend API (port 8000 par défaut)
# Utilisée par le proxy webpack (npm run web) et par l'app en dev.
# Pour un appareil physique ou autre machine : http://IP_DU_SERVEUR:8000
REACT_APP_API_URL=http://localhost:8000

# URL de l'app web (pour le paiement Stripe après commande : redirection vers /checkout-pay)
# En prod : https://afrodine.com ou votre domaine
REACT_APP_WEB_APP_URL=http://localhost:3000
